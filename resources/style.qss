    background-color: #191a1a;
    color: #acabaa;
    border: none;
    border-radius: 4px;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: 600;
}

VideoPlayerWidget QPushButton:hover,
QWidget#video_player_pane QPushButton:hover {
    background-color: #262626;
    color: #e7e5e4;
}

VideoPlayerWidget QPushButton:pressed,
QWidget#video_player_pane QPushButton:pressed {
    background-color: #1f2020;
    color: #71d7cd;
}

/* Action CTA buttons in preview */
VideoPlayerWidget QPushButton[objectName="insert_btn"],
VideoPlayerWidget QPushButton[objectName="reveal_btn"],
VideoPlayerWidget QPushButton[objectName="fetch_btn"],
QWidget#video_player_pane QPushButton[objectName="insert_btn"],
QWidget#video_player_pane QPushButton[objectName="reveal_btn"],
QWidget#video_player_pane QPushButton[objectName="fetch_btn"] {
    background-color: rgba(113, 215, 205, 0);
    color: #71d7cd;
    border: 1px solid rgba(113, 215, 205, 0.24);
    border-radius: 5px;
    padding: 8px 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
}

VideoPlayerWidget QPushButton[objectName="insert_btn"]:hover,
VideoPlayerWidget QPushButton[objectName="reveal_btn"]:hover,
VideoPlayerWidget QPushButton[objectName="fetch_btn"]:hover {
    background-color: rgba(113, 215, 205, 0.10);
    border-color: rgba(113, 215, 205, 0.40);
}

/* Ghost dividers in preview */
VideoPlayerWidget QFrame[frameShape="4"],
VideoPlayerWidget QFrame[frameShape="5"],
QWidget#video_player_pane QFrame[frameShape="4"],
QWidget#video_player_pane QFrame[frameShape="5"] {
    background-color: rgba(72, 72, 72, 0.14);
    max-height: 1px;
}

/* Scrollbar in preview */
VideoPlayerWidget QScrollBar:vertical,
QWidget#video_player_pane QScrollBar:vertical {
    background-color: #191a1a;
    width: 4px;
    border: none;
    margin: 0;
}

VideoPlayerWidget QScrollBar::handle:vertical,
QWidget#video_player_pane QScrollBar::handle:vertical {
    background-color: rgba(72, 72, 72, 0.45);
    border-radius: 2px;
    min-height: 20px;
}

VideoPlayerWidget QScrollBar::add-line:vertical,
VideoPlayerWidget QScrollBar::sub-line:vertical,
VideoPlayerWidget QScrollBar::add-page:vertical,
VideoPlayerWidget QScrollBar::sub-page:vertical,
QWidget#video_player_pane QScrollBar::add-line:vertical,
QWidget#video_player_pane QScrollBar::sub-line:vertical,
QWidget#video_player_pane QScrollBar::add-page:vertical,
QWidget#video_player_pane QScrollBar::sub-page:vertical {
    height: 0;
    background: #191a1a;
    border: none;
}


/* ══════════════════════════════════════════════════════════════════════════════
   8. DOCK WIDGETS — History, Settings, Analytics   (#191a1a)
   ════════════════════════════════════════════════════════════════════════════ */

QDockWidget {
    background-color: #191a1a;
    color: #e7e5e4;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
}

QDockWidget::title {
    background-color: #131313;
    color: #acabaa;
    padding: 8px 14px;
    text-align: left;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.15);
}

QDockWidget::close-button,
QDockWidget::float-button {
    background-color: #131313;
    border: none;
    border-radius: 3px;
    padding: 2px;
    subcontrol-position: top right;
    subcontrol-origin: margin;
}

QDockWidget::close-button:hover,
QDockWidget::float-button:hover {
    background-color: #262626;
}

/* Dock content widgets */
HistoryPanel,
SettingsPanel,
AnalyticsPanel {
    background-color: #191a1a;
}

HistoryPanel QWidget,
SettingsPanel QWidget,
AnalyticsPanel QWidget {
    background-color: #191a1a;
}

HistoryPanel QAbstractItemView,
SettingsPanel QAbstractItemView,
AnalyticsPanel QAbstractItemView {
    background-color: #191a1a;
    alternate-background-color: #1f2020;
    color: #acabaa;
    border: none;
    outline: none;
    selection-background-color: #262626;
    selection-color: #71d7cd;
}

HistoryPanel QAbstractItemView::item,
SettingsPanel QAbstractItemView::item,
AnalyticsPanel QAbstractItemView::item {
    background-color: #191a1a;
    color: #acabaa;
    padding: 6px 10px;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.09);
}

HistoryPanel QAbstractItemView::item:hover,
AnalyticsPanel QAbstractItemView::item:hover {
    background-color: #262626;
    color: #e7e5e4;
}

HistoryPanel QAbstractScrollArea,
SettingsPanel QAbstractScrollArea,
AnalyticsPanel QAbstractScrollArea {
    background-color: #191a1a;
}

HistoryPanel QAbstractScrollArea > QWidget,
SettingsPanel QAbstractScrollArea > QWidget,
AnalyticsPanel QAbstractScrollArea > QWidget {
    background-color: #191a1a;
}

HistoryPanel QLabel,
SettingsPanel QLabel,
AnalyticsPanel QLabel {
    background-color: #191a1a;
    color: #acabaa;
    font-size: 11px;
}

/* Settings panel form elements */
SettingsPanel QGroupBox {
    background-color: #191a1a;
    border: 1px solid rgba(72, 72, 72, 0.20);
    border-radius: 7px;
    margin-top: 16px;
    padding-top: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #acabaa;
    text-transform: uppercase;
}

SettingsPanel QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    left: 12px;
    color: #acabaa;
    background-color: #191a1a;
}

SettingsPanel QScrollArea,
SettingsPanel QScrollArea > QWidget,
SettingsPanel QScrollArea > QWidget > QWidget {
    background-color: #191a1a;
}

/* Analytics tabs */
AnalyticsPanel QTabWidget::pane {
    background-color: #191a1a;
    border: none;
    border-top: 1px solid rgba(72, 72, 72, 0.15);
}

AnalyticsPanel QTabWidget > QWidget {
    background-color: #191a1a;
}

AnalyticsPanel QTabBar {
    background-color: #131313;
}

AnalyticsPanel QTabBar::tab {
    background-color: #131313;
    color: #acabaa;
    padding: 7px 16px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    margin-right: 2px;
}

AnalyticsPanel QTabBar::tab:selected {
    background-color: #131313;
    color: #71d7cd;
    border-bottom: 2px solid #71d7cd;
}

AnalyticsPanel QTabBar::tab:hover {
    background-color: #191a1a;
    color: #e7e5e4;
}

/* Header in history/analytics */
HistoryPanel QHeaderView::section,
SettingsPanel QHeaderView::section,
AnalyticsPanel QHeaderView::section {
    background-color: #131313;
    color: #acabaa;
    padding: 6px 10px;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.15);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}


/* ══════════════════════════════════════════════════════════════════════════════
   9. GLOBAL WIDGET FALLBACKS
   ════════════════════════════════════════════════════════════════════════════ */

/* Scrollbars — global 4px, no arrows */
QScrollBar:vertical {
    background-color: #0e0e0e;
    width: 4px;
    border: none;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: rgba(72, 72, 72, 0.45);
    border-radius: 2px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background-color: rgba(72, 72, 72, 0.75);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    height: 0;
    background: #0e0e0e;
    border: none;
}

QScrollBar:horizontal {
    background-color: #0e0e0e;
    height: 4px;
    border: none;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: rgba(72, 72, 72, 0.45);
    border-radius: 2px;
    min-width: 24px;
}

QScrollBar::handle:horizontal:hover {
    background-color: rgba(72, 72, 72, 0.75);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    width: 0;
    background: #0e0e0e;
    border: none;
}

/* QPushButton */
QPushButton {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-radius: 5px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #2c2c2c;
    color: #e7e5e4;
}

QPushButton:pressed {
    background-color: #1f2020;
    color: #71d7cd;
}

QPushButton:disabled {
    background-color: #191a1a;
    color: rgba(172, 171, 170, 0.32);
}

/* QLineEdit */
QLineEdit {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    border-radius: 5px;
    padding: 5px 10px;
    font-size: 11px;
    selection-background-color: rgba(113, 215, 205, 0.25);
}

QLineEdit:focus {
    border-bottom: 2px solid #71d7cd;
}

QLineEdit:disabled {
    background-color: #191a1a;
    color: rgba(172, 171, 170, 0.35);
}

/* QComboBox */
QComboBox {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    border-radius: 5px;
    padding: 5px 8px;
    font-size: 11px;
}

QComboBox:focus {
    border-bottom: 2px solid #71d7cd;
}

QComboBox::drop-down {
    background-color: #262626;
    border: none;
    width: 18px;
    subcontrol-position: right center;
}

QComboBox QAbstractItemView {
    background-color: #2c2c2c;
    border: 1px solid rgba(72, 72, 72, 0.22);
    border-radius: 5px;
    color: #e7e5e4;
    selection-background-color: #1f2020;
    selection-color: #71d7cd;
    outline: none;
    padding: 4px;
}

/* QSpinBox */
QSpinBox, QDoubleSpinBox {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    border-radius: 5px;
    padding: 5px 8px;
    font-size: 11px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-bottom: 2px solid #71d7cd;
}

QSpinBox::up-button, QSpinBox::down-button,
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    background-color: #2c2c2c;
    border: none;
    width: 16px;
    border-radius: 2px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover,
QDoubleSpinBox::up-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #484848;
}

/* QCheckBox */
QCheckBox {
    background-color: #0e0e0e;
    color: #acabaa;
    font-size: 11px;
    spacing: 7px;
}

QCheckBox:hover { color: #e7e5e4; }

QCheckBox::indicator {
    width: 15px;
    height: 15px;
    border-radius: 3px;
    background-color: #262626;
    border: 1px solid rgba(72, 72, 72, 0.40);
}

QCheckBox::indicator:checked {
    background-color: #71d7cd;
    border-color: #71d7cd;
    image: url(:/icons/checked.svg);
}

QCheckBox::indicator:unchecked {
    image: url(:/icons/unchecked.svg);
}

/* QLabel */
QLabel {
    background-color: #0e0e0e;
    color: #acabaa;
    font-size: 11px;
}

/* QGroupBox */
QGroupBox {
    background-color: #191a1a;
    border: 1px solid rgba(72, 72, 72, 0.20);
    border-radius: 7px;
    margin-top: 16px;
    padding-top: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #acabaa;
    text-transform: uppercase;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 8px;
    left: 12px;
    background-color: #191a1a;
    color: #acabaa;
}

/* QTabWidget / QTabBar */
QTabWidget {
    background-color: #191a1a;
}

QTabWidget::pane {
    background-color: #191a1a;
    border: none;
    border-top: 1px solid rgba(72, 72, 72, 0.15);
}

QTabWidget > QWidget {
    background-color: #191a1a;
}

QTabBar {
    background-color: #131313;
}

QTabBar::tab {
    background-color: #131313;
    color: #acabaa;
    padding: 7px 16px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    margin-right: 2px;
}

QTabBar::tab:selected {
    background-color: #131313;
    color: #71d7cd;
    border-bottom: 2px solid #71d7cd;
}

QTabBar::tab:hover {
    background-color: #191a1a;
    color: #e7e5e4;
}

/* QHeaderView */
QHeaderView {
    background-color: #0e0e0e;
}

QHeaderView::section {
    background-color: #131313;
    color: #acabaa;
    padding: 6px 10px;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.15);
    border-right: 1px solid rgba(72, 72, 72, 0.08);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}

QHeaderView::section:hover {
    background-color: #191a1a;
    color: #e7e5e4;
}

/* QSlider global */
QSlider::groove:horizontal {
    height: 2px;
    background-color: #262626;
    border-radius: 1px;
}

QSlider::handle:horizontal {
    background-color: #71d7cd;
    width: 12px;
    height: 12px;
    border-radius: 6px;
    margin: -5px 0;
}

QSlider::sub-page:horizontal {
    background-color: #71d7cd;
    border-radius: 1px;
}

QSlider::add-page:horizontal {
    background-color: #262626;
    border-radius: 1px;
}

/* QProgressBar */
QProgressBar {
    background-color: #262626;
    border: none;
    border-radius: 3px;
    color: #acabaa;
    font-size: 10px;
    text-align: center;
    min-height: 4px;
    max-height: 4px;
}

QProgressBar::chunk {
    background-color: qlineargradient(
        spread:pad, x1:0, y1:0, x2:1, y2:0,
        stop:0 #71d7cd, stop:1 #0a8b82
    );
    border-radius: 3px;
}

/* Dialogs */
QDialog {
    background-color: #191a1a;
    color: #e7e5e4;
}

QDialog QWidget {
    background-color: #191a1a;
}

QDialog QLabel {
    background-color: #191a1a;
    color: #e7e5e4;
    font-size: 12px;
}

QDialog QAbstractItemView {
    background-color: #191a1a;
    alternate-background-color: #1f2020;
    color: #e7e5e4;
    border: none;
    outline: none;
    selection-background-color: #262626;
    selection-color: #71d7cd;
}

QDialog QAbstractScrollArea,
QDialog QAbstractScrollArea > QWidget,
QDialog QAbstractScrollArea > QWidget > QWidget {
    background-color: #191a1a;
}

QMessageBox {
    background-color: #191a1a;
    color: #e7e5e4;
}

QMessageBox QLabel {
    background-color: #191a1a;
    color: #e7e5e4;
    font-size: 12px;
}

QProgressDialog {
    background-color: #191a1a;
    color: #e7e5e4;
    border: 1px solid rgba(72, 72, 72, 0.22);
    border-radius: 8px;
}

QProgressDialog QLabel {
    background-color: #191a1a;
    color: #e7e5e4;
    font-size: 12px;
}

QFileDialog {
    background-color: #191a1a;
    color: #e7e5e4;
}

QFileDialog QWidget {
    background-color: #191a1a;
}

QFileDialog QAbstractItemView {
    background-color: #191a1a;
    color: #e7e5e4;
    border: none;
}

/* QToolTip */
QToolTip {
    background-color: #2c2c2c;
    color: #e7e5e4;
    border: 1px solid rgba(72, 72, 72, 0.25);
    border-radius: 5px;
    padding: 5px 9px;
    font-size: 10px;
    font-weight: 500;
}

/* MediaInfoPopup */
MediaInfoPopup {
    background-color: #2c2c2c;
    border: 1px solid rgba(72, 72, 72, 0.22);
    border-radius: 9px;
}

MediaInfoPopup QWidget {
    background-color: #2c2c2c;
}

MediaInfoPopup QLabel {
    background-color: #2c2c2c;
    color: #e7e5e4;
    font-size: 11px;
}

/* Ghost QFrame dividers */
QFrame[frameShape="4"] {
    background-color: rgba(72, 72, 72, 0.15);
    border: none;
    max-height: 1px;
}

QFrame[frameShape="5"] {
    background-color: rgba(72, 72, 72, 0.15);
    border: none;
    max-width: 1px;
}
