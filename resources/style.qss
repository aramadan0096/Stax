/* ============================================================================
   StaX — style.qss   Cinematic Orchestrator design system
   ============================================================================
   ROOT CAUSE FIX: QAbstractItemView (QTreeWidget, QListWidget, QTableWidget)
   paints its background using QPalette::Base, NOT via widget inheritance.
   On Windows this defaults to white regardless of QWidget { background }.
   Every item-view and scroll-area viewport MUST be explicitly overridden.

   Surface triptych:
     #131313  toolbar / menu strip
     #191a1a  LEFT nav + RIGHT preview  (elevated — slightly brighter)
     #0e0e0e  CENTER media workbench   (darkest)
     #1f2020  hover
     #262626  selected / active / cards
     #2c2c2c  menus / tooltips / floating overlays

   Panel selectors use BOTH class-name AND objectName variants.
   Add these three lines to MainWindow.setup_ui() for guaranteed matching:
     self.stacks_panel.setObjectName("stacks_panel")
     self.media_display.setObjectName("media_display")
     self.video_player_pane.setObjectName("video_player_pane")
   ============================================================================ */


/* ── 1. NUCLEAR DARK BASE ────────────────────────────────────────────────────
   QWidget covers container widgets.
   QAbstractItemView MUST be listed separately — it does NOT inherit bg.
   QAbstractScrollArea viewport() is a plain QWidget child, also explicit. */

QWidget {
    background-color: #0e0e0e;
    color: #e7e5e4;
    border: none;
    outline: none;
    selection-background-color: rgba(113, 215, 205, 0.25);
    selection-color: #e7e5e4;
}

/* Item views: tree, list, table — QPalette::Base controls their fill */
QAbstractItemView {
    background-color: #0e0e0e;
    alternate-background-color: rgba(31, 32, 32, 0.6);
    color: #e7e5e4;
    border: none;
    outline: none;
    gridline-color: rgba(72, 72, 72, 0.10);
    selection-background-color: #262626;
    selection-color: #71d7cd;
    show-decoration-selected: 1;
}

QAbstractItemView::item {
    background-color: #0e0e0e;
    color: #acabaa;
    padding: 4px 8px;
    border: none;
}

QAbstractItemView::item:hover {
    background-color: #1f2020;
    color: #e7e5e4;
}

QAbstractItemView::item:selected {
    background-color: #262626;
    color: #71d7cd;
}

/* Scroll area viewports: the viewport() child is a plain QWidget */
QAbstractScrollArea {
    background-color: #0e0e0e;
}

QAbstractScrollArea > QWidget,
QAbstractScrollArea > QWidget > QWidget {
    background-color: #0e0e0e;
}

/* ── 2. MAIN WINDOW & SPLITTER ───────────────────────────────────────────── */

QMainWindow {
    background-color: #0e0e0e;
}

QMainWindow::separator {
    background-color: rgba(72, 72, 72, 0.12);
    width: 1px;
    height: 1px;
}

QSplitter {
    background-color: #0e0e0e;
}

QSplitter::handle {
    background-color: rgba(72, 72, 72, 0.12);
    width: 1px;
    height: 1px;
}

QSplitter::handle:horizontal { width: 1px; }
QSplitter::handle:vertical   { height: 1px; }


/* ── 3. TOOLBAR & MENU BAR ───────────────────────────────────────────────── */

QToolBar {
    background-color: #131313;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.14);
    padding: 3px 6px;
    spacing: 2px;
}

QToolBar::separator {
    background-color: rgba(72, 72, 72, 0.28);
    width: 1px;
    margin: 4px 3px;
}

QToolButton {
    background-color: #131313;
    color: #acabaa;
    border: none;
    border-radius: 5px;
    padding: 6px 8px;
    font-size: 11px;
    font-weight: 500;
}

QToolButton:hover {
    background-color: #262626;
    color: #e7e5e4;
}

QToolButton:pressed,
QToolButton:checked {
    background-color: rgba(113, 215, 205, 0.12);
    color: #71d7cd;
}

QMenuBar {
    background-color: #131313;
    color: #acabaa;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.14);
    padding: 2px 4px;
    font-size: 11px;
}

QMenuBar::item {
    background-color: #131313;
    padding: 4px 10px;
    border-radius: 4px;
    color: #acabaa;
}

QMenuBar::item:selected {
    background-color: #262626;
    color: #e7e5e4;
}

QMenuBar::item:pressed {
    background-color: #1f2020;
    color: #71d7cd;
}

QMenu {
    background-color: #2c2c2c;
    border: 1px solid rgba(72, 72, 72, 0.22);
    border-radius: 7px;
    padding: 5px 3px;
    font-size: 11px;
    color: #e7e5e4;
}

QMenu::item {
    background-color: #2c2c2c;
    padding: 6px 28px 6px 12px;
    border-radius: 4px;
    color: #e7e5e4;
    margin: 1px 3px;
}

QMenu::item:selected {
    background-color: #1f2020;
    color: #71d7cd;
}

QMenu::item:disabled {
    color: rgba(172, 171, 170, 0.35);
}

QMenu::separator {
    height: 1px;
    background-color: rgba(72, 72, 72, 0.18);
    margin: 4px 10px;
    border: none;
}


/* ── 4. STATUS BAR ───────────────────────────────────────────────────────── */

QStatusBar {
    background-color: #0e0e0e;
    color: #acabaa;
    font-size: 10px;
    border: none;
    border-top: 1px solid rgba(72, 72, 72, 0.13);
}

QStatusBar::item { border: none; }

QStatusBar QLabel {
    background-color: #0e0e0e;
    color: #acabaa;
    font-size: 10px;
    padding: 0 6px;
}


/* ══════════════════════════════════════════════════════════════════════════════
   5. LEFT PANEL — StacksListsPanel / #stacks_panel   (#191a1a — elevated)
   ════════════════════════════════════════════════════════════════════════════ */

/* Class name selector (works if Python class registers with Qt meta-object) */
StacksListsPanel {
    background-color: #191a1a;
    border: none;
    border-right: 1px solid rgba(72, 72, 72, 0.12);
}

/* objectName selector (guaranteed — requires setObjectName in Python) */
QWidget#stacks_panel {
    background-color: #191a1a;
    border: none;
    border-right: 1px solid rgba(72, 72, 72, 0.12);
}

/* All child QWidgets inside nav panel */
StacksListsPanel QWidget,
QWidget#stacks_panel QWidget {
    background-color: #191a1a;
}

/* Item views inside nav — override QAbstractItemView global rule */
StacksListsPanel QAbstractItemView,
QWidget#stacks_panel QAbstractItemView {
    background-color: #191a1a;
    alternate-background-color: #191a1a;
    border: none;
    outline: none;
    selection-background-color: #262626;
    selection-color: #71d7cd;
}

StacksListsPanel QAbstractItemView::item,
QWidget#stacks_panel QAbstractItemView::item {
    background-color: #191a1a;
    color: #acabaa;
    padding: 0 8px;
    height: 32px;
    border: none;
    border-left: 3px solid transparent;
    border-radius: 0;
}

StacksListsPanel QAbstractItemView::item:hover,
QWidget#stacks_panel QAbstractItemView::item:hover {
    background-color: #1f2020;
    color: #e7e5e4;
}

StacksListsPanel QAbstractItemView::item:selected,
QWidget#stacks_panel QAbstractItemView::item:selected {
    background-color: #262626;
    color: #71d7cd;
    border-left: 3px solid #71d7cd;
}

/* Tree branch chrome */
StacksListsPanel QTreeView::branch,
QWidget#stacks_panel QTreeView::branch {
    background-color: #191a1a;
    border: none;
}

/* Scroll areas inside nav */
StacksListsPanel QAbstractScrollArea,
QWidget#stacks_panel QAbstractScrollArea {
    background-color: #191a1a;
}

StacksListsPanel QAbstractScrollArea > QWidget,
StacksListsPanel QAbstractScrollArea > QWidget > QWidget,
QWidget#stacks_panel QAbstractScrollArea > QWidget,
QWidget#stacks_panel QAbstractScrollArea > QWidget > QWidget {
    background-color: #191a1a;
}

/* Frame + QLabel inside nav */
StacksListsPanel QFrame,
QWidget#stacks_panel QFrame {
    background-color: #191a1a;
    border: none;
}

StacksListsPanel QLabel,
QWidget#stacks_panel QLabel {
    background-color: #191a1a;
    color: #acabaa;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
}

/* Buttons in nav */
StacksListsPanel QPushButton,
QWidget#stacks_panel QPushButton {
    background-color: #262626;
    color: #acabaa;
    border: none;
    border-radius: 5px;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 600;
}

StacksListsPanel QPushButton:hover,
QWidget#stacks_panel QPushButton:hover {
    background-color: #2c2c2c;
    color: #e7e5e4;
}

StacksListsPanel QPushButton:pressed,
QWidget#stacks_panel QPushButton:pressed {
    background-color: #1f2020;
    color: #71d7cd;
}

StacksListsPanel QPushButton:checked,
QWidget#stacks_panel QPushButton:checked {
    background-color: rgba(113, 215, 205, 0.10);
    color: #71d7cd;
}

/* New Playlist primary CTA */
StacksListsPanel QPushButton#add_playlist_btn,
QWidget#stacks_panel QPushButton#add_playlist_btn {
    background-color: qlineargradient(
        spread:pad, x1:0, y1:0, x2:1, y2:1,
        stop:0 #71d7cd, stop:1 #0a8b82
    );
    color: #003e39;
    font-weight: 700;
    border-radius: 6px;
    border: none;
}

/* Inputs in nav */
StacksListsPanel QLineEdit,
QWidget#stacks_panel QLineEdit {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    border-radius: 5px;
    padding: 5px 10px;
    font-size: 11px;
}

StacksListsPanel QLineEdit:focus,
QWidget#stacks_panel QLineEdit:focus {
    border-bottom: 2px solid #71d7cd;
}

/* Scrollbar in nav */
StacksListsPanel QScrollBar:vertical,
QWidget#stacks_panel QScrollBar:vertical {
    background-color: #191a1a;
    width: 4px;
    border: none;
    margin: 0;
}

StacksListsPanel QScrollBar::handle:vertical,
QWidget#stacks_panel QScrollBar::handle:vertical {
    background-color: rgba(72, 72, 72, 0.50);
    border-radius: 2px;
    min-height: 20px;
}

StacksListsPanel QScrollBar::add-line:vertical,
StacksListsPanel QScrollBar::sub-line:vertical,
StacksListsPanel QScrollBar::add-page:vertical,
StacksListsPanel QScrollBar::sub-page:vertical,
QWidget#stacks_panel QScrollBar::add-line:vertical,
QWidget#stacks_panel QScrollBar::sub-line:vertical,
QWidget#stacks_panel QScrollBar::add-page:vertical,
QWidget#stacks_panel QScrollBar::sub-page:vertical {
    height: 0;
    background: #191a1a;
    border: none;
}

/* Divider lines in nav */
StacksListsPanel QFrame[frameShape="4"],
StacksListsPanel QFrame[frameShape="5"],
QWidget#stacks_panel QFrame[frameShape="4"],
QWidget#stacks_panel QFrame[frameShape="5"] {
    background-color: rgba(72, 72, 72, 0.15);
    max-height: 1px;
}


/* ══════════════════════════════════════════════════════════════════════════════
   6. CENTER PANEL — MediaDisplayWidget / #media_display   (#0e0e0e — darkest)
   Uses the global QAbstractItemView dark rule, just locks it explicitly.
   ════════════════════════════════════════════════════════════════════════════ */

MediaDisplayWidget,
QWidget#media_display {
    background-color: #0e0e0e;
    border: none;
}

MediaDisplayWidget QWidget,
QWidget#media_display QWidget {
    background-color: #0e0e0e;
}

MediaDisplayWidget QAbstractItemView,
QWidget#media_display QAbstractItemView {
    background-color: #0e0e0e;
    alternate-background-color: rgba(31, 32, 32, 0.5);
    border: none;
    outline: none;
    selection-background-color: #262626;
    selection-color: #71d7cd;
}

MediaDisplayWidget QAbstractItemView::item,
QWidget#media_display QAbstractItemView::item {
    background-color: #191a1a;
    color: #acabaa;
    border-radius: 6px;
    margin: 4px;
    border: 1px solid rgba(72, 72, 72, 0);
}

MediaDisplayWidget QAbstractItemView::item:hover,
QWidget#media_display QAbstractItemView::item:hover {
    background-color: #1f2020;
    color: #e7e5e4;
}

MediaDisplayWidget QAbstractItemView::item:selected,
QWidget#media_display QAbstractItemView::item:selected {
    background-color: #262626;
    color: #71d7cd;
    border: 1px solid rgba(113, 215, 205, 0.30);
}

MediaDisplayWidget QAbstractScrollArea,
QWidget#media_display QAbstractScrollArea {
    background-color: #0e0e0e;
}

MediaDisplayWidget QAbstractScrollArea > QWidget,
MediaDisplayWidget QAbstractScrollArea > QWidget > QWidget,
QWidget#media_display QAbstractScrollArea > QWidget,
QWidget#media_display QAbstractScrollArea > QWidget > QWidget {
    background-color: #0e0e0e;
}

MediaDisplayWidget QHeaderView,
QWidget#media_display QHeaderView {
    background-color: #0e0e0e;
}

MediaDisplayWidget QHeaderView::section,
QWidget#media_display QHeaderView::section {
    background-color: #131313;
    color: #acabaa;
    padding: 6px 10px;
    border: none;
    border-bottom: 1px solid rgba(72, 72, 72, 0.15);
    border-right: 1px solid rgba(72, 72, 72, 0.08);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
}

MediaDisplayWidget QHeaderView::section:hover,
QWidget#media_display QHeaderView::section:hover {
    background-color: #191a1a;
    color: #e7e5e4;
}

MediaDisplayWidget QLabel,
QWidget#media_display QLabel {
    background-color: #0e0e0e;
    color: #acabaa;
    font-size: 11px;
}

MediaDisplayWidget QPushButton,
QWidget#media_display QPushButton {
    background-color: #262626;
    color: #acabaa;
    border: none;
    border-radius: 5px;
    padding: 5px 10px;
    font-size: 11px;
    font-weight: 600;
}

MediaDisplayWidget QPushButton:hover,
QWidget#media_display QPushButton:hover {
    background-color: #2c2c2c;
    color: #e7e5e4;
}

MediaDisplayWidget QPushButton:pressed,
MediaDisplayWidget QPushButton:checked,
QWidget#media_display QPushButton:pressed,
QWidget#media_display QPushButton:checked {
    background-color: rgba(113, 215, 205, 0.12);
    color: #71d7cd;
}

MediaDisplayWidget QLineEdit,
QWidget#media_display QLineEdit {
    background-color: #262626;
    color: #e7e5e4;
    border: none;
    border-bottom: 2px solid rgba(113, 215, 205, 0);
    border-radius: 5px;
    padding: 5px 10px;
    font-size: 11px;
}

MediaDisplayWidget QLineEdit:focus,
QWidget#media_display QLineEdit:focus {
    border-bottom: 2px solid #71d7cd;
}

/* Size slider */
MediaDisplayWidget QSlider::groove:horizontal,
QWidget#media_display QSlider::groove:horizontal {
    height: 2px;
    background-color: #262626;
    border-radius: 1px;
}

MediaDisplayWidget QSlider::handle:horizontal,
QWidget#media_display QSlider::handle:horizontal {
    background-color: #71d7cd;
    width: 12px;
    height: 12px;
    border-radius: 6px;
    margin: -5px 0;
}

MediaDisplayWidget QSlider::sub-page:horizontal,
QWidget#media_display QSlider::sub-page:horizontal {
    background-color: #71d7cd;
    border-radius: 1px;
}

MediaDisplayWidget QSlider::add-page:horizontal,
QWidget#media_display QSlider::add-page:horizontal {
    background-color: #262626;
    border-radius: 1px;
}

/* Scrollbar in center */
MediaDisplayWidget QScrollBar:vertical,
QWidget#media_display QScrollBar:vertical {
    background-color: #0e0e0e;
    width: 4px;
    border: none;
    margin: 0;
}

MediaDisplayWidget QScrollBar::handle:vertical,
QWidget#media_display QScrollBar::handle:vertical {
    background-color: rgba(72, 72, 72, 0.45);
    border-radius: 2px;
    min-height: 20px;
}

MediaDisplayWidget QScrollBar::add-line:vertical,
MediaDisplayWidget QScrollBar::sub-line:vertical,
MediaDisplayWidget QScrollBar::add-page:vertical,
MediaDisplayWidget QScrollBar::sub-page:vertical,
QWidget#media_display QScrollBar::add-line:vertical,
QWidget#media_display QScrollBar::sub-line:vertical,
QWidget#media_display QScrollBar::add-page:vertical,
QWidget#media_display QScrollBar::sub-page:vertical {
    height: 0;
    background: #0e0e0e;
    border: none;
}

MediaDisplayWidget QScrollBar:horizontal,
QWidget#media_display QScrollBar:horizontal {
    background-color: #0e0e0e;
    height: 4px;
    border: none;
    margin: 0;
}

MediaDisplayWidget QScrollBar::handle:horizontal,
QWidget#media_display QScrollBar::handle:horizontal {
    background-color: rgba(72, 72, 72, 0.45);
    border-radius: 2px;
    min-width: 20px;
}

MediaDisplayWidget QScrollBar::add-line:horizontal,
MediaDisplayWidget QScrollBar::sub-line:horizontal,
MediaDisplayWidget QScrollBar::add-page:horizontal,
MediaDisplayWidget QScrollBar::sub-page:horizontal,
QWidget#media_display QScrollBar::add-line:horizontal,
QWidget#media_display QScrollBar::sub-line:horizontal,
QWidget#media_display QScrollBar::add-page:horizontal,
QWidget#media_display QScrollBar::sub-page:horizontal {
    width: 0;
    background: #0e0e0e;
    border: none;
}


/* ══════════════════════════════════════════════════════════════════════════════
   7. RIGHT PANEL — VideoPlayerWidget / #video_player_pane  (#191a1a — elevated)
   ════════════════════════════════════════════════════════════════════════════ */

VideoPlayerWidget,
QWidget#video_player_pane {
    background-color: #191a1a;
    border: none;
    border-left: 1px solid rgba(72, 72, 72, 0.12);
}

VideoPlayerWidget QWidget,
QWidget#video_player_pane QWidget {
    background-color: #191a1a;
}

VideoPlayerWidget QAbstractItemView,
QWidget#video_player_pane QAbstractItemView {
    background-color: #191a1a;
    border: none;
    outline: none;
}

VideoPlayerWidget QAbstractScrollArea,
QWidget#video_player_pane QAbstractScrollArea {
    background-color: #191a1a;
}

VideoPlayerWidget QAbstractScrollArea > QWidget,
VideoPlayerWidget QAbstractScrollArea > QWidget > QWidget,
QWidget#video_player_pane QAbstractScrollArea > QWidget,
QWidget#video_player_pane QAbstractScrollArea > QWidget > QWidget {
    background-color: #191a1a;
}

VideoPlayerWidget QFrame,
QWidget#video_player_pane QFrame {
    background-color: #191a1a;
    border: none;
}

VideoPlayerWidget QLabel,
QWidget#video_player_pane QLabel {
    background-color: #191a1a;
    color: #acabaa;
    font-size: 11px;
}

/* Timeline — indigo playhead = "Time", not the teal "Process" colour */
VideoPlayerWidget QSlider::groove:horizontal,
QWidget#video_player_pane QSlider::groove:horizontal {
    height: 3px;
    background-color: #262626;
    border-radius: 2px;
}

VideoPlayerWidget QSlider::handle:horizontal,
QWidget#video_player_pane QSlider::handle:horizontal {
    background-color: #bac3ff;
    width: 13px;
    height: 13px;
    border-radius: 7px;
    margin: -5px 0;
    border: 2px solid #191a1a;
}

VideoPlayerWidget QSlider::handle:horizontal:hover,
QWidget#video_player_pane QSlider::handle:horizontal:hover {
    background-color: #dee0ff;
}

VideoPlayerWidget QSlider::sub-page:horizontal,
QWidget#video_player_pane QSlider::sub-page:horizontal {
    background-color: #71d7cd;
    border-radius: 2px;
}

VideoPlayerWidget QSlider::add-page:horizontal,
